MaterialFamily(
    label: "Voxel Surface",
    surface_model: "stylized_pbr_lite",
    texture_slots: [
        (name: "albedo", kind: albedo, required: true),
        (name: "normal", kind: normal, required: false),
        (name: "roughness", kind: roughness, required: false),
    ],
    scalar_parameters: [
        (name: "roughness", default: 0.72, min: 0.0, max: 1.0),
    ],
    color_parameters: [
        (name: "tint", default: [1.0, 1.0, 1.0, 1.0]),
    ],
)

