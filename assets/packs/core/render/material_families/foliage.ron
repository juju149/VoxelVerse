MaterialFamily(
    label: "Foliage",
    surface_model: "foliage_lit",
    texture_slots: [
        (name: "albedo", kind: albedo, required: true),
        (name: "normal", kind: normal, required: false),
    ],
    scalar_parameters: [
        (name: "alpha_cutoff", default: 0.45, min: 0.0, max: 1.0),
    ],
    color_parameters: [
        (name: "biome_tint", default: [0.7, 1.0, 0.62, 1.0]),
    ],
)

