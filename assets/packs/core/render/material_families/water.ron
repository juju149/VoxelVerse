MaterialFamily(
    label: "Water",
    surface_model: "water_lit",
    texture_slots: [
        (name: "albedo", kind: albedo, required: false),
        (name: "normal", kind: normal, required: false),
    ],
    scalar_parameters: [
        (name: "wave_strength", default: 0.25, min: 0.0, max: 1.0),
        (name: "clarity", default: 0.65, min: 0.0, max: 1.0),
    ],
    color_parameters: [
        (name: "water_tint", default: [0.26, 0.58, 0.82, 0.72]),
    ],
)

