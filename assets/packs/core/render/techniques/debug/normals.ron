// Technique: Debug Normals
//
// Renders world-space normals as RGB colors for debugging surface orientation.
// Used by the debug render graph only — never active in production.
RenderTechnique(
    label: "Debug Normals",
    pass: "debug",
    stages: (
        vertex: "core:render/shader_modules/voxel/terrain_vertex",
        fragment: Some("core:render/shader_modules/debug/normals"),
    ),
    vertex_layout: "terrain_chunk_mesh",
    material_family: "core:render/material_families/voxel_surface",
    contracts: [
        "core:render/shader_contracts/frame_globals",
        "core:render/shader_contracts/planet_globals",
        "core:render/shader_contracts/camera_globals",
    ],
    depth: (write: true, compare: less_equal),
    culling: none,
    blend: opaque,
    outputs: [
        "debug_color",
    ],
    features: [
        "depth_only",
    ],
    profile_overrides: [],
)
