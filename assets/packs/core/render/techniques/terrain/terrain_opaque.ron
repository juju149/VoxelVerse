RenderTechnique(
    label: "Terrain Opaque",
    pass: "terrain_opaque",
    stages: (
        vertex: "core:render/shader_modules/voxel/terrain_vertex",
        fragment: Some("core:render/shader_modules/surface/stylized_pbr_lite"),
    ),
    vertex_layout: "terrain_chunk_mesh",
    material_family: "core:render/material_families/voxel_surface",
    contracts: [
        "core:render/shader_contracts/frame_globals",
        "core:render/shader_contracts/camera_globals",
        "core:render/shader_contracts/planet_globals",
        "core:render/shader_contracts/lighting_globals",
        "core:render/shader_contracts/material_surface",
    ],
    depth: (write: true, compare: less_equal),
    culling: none,
    blend: opaque,
    outputs: [
        "main_color",
        "motion_vectors",
    ],
    features: [
        "texture_array",
        "voxel_ao",
        "face_variation",
        "curvature_fog",
        "normal_maps",
        "roughness_maps",
    ],
    profile_overrides: [
        (
            profile: "core:render/profiles/potato",
            enable_features: ["texture_array", "curvature_fog"],
            disable_features: ["normal_maps", "roughness_maps", "face_variation"],
        ),
    ],
)

