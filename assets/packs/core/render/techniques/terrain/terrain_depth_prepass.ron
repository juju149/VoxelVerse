RenderTechnique(
    label: "Terrain Depth Prepass",
    pass: "terrain_depth_prepass",
    stages: (
        vertex: "core:render/shader_modules/voxel/terrain_vertex",
        fragment: None,
    ),
    vertex_layout: "terrain_chunk_mesh",
    material_family: "core:render/material_families/voxel_surface",
    contracts: [
        "core:render/shader_contracts/frame_globals",
        "core:render/shader_contracts/camera_globals",
        "core:render/shader_contracts/planet_globals",
    ],
    depth: (write: true, compare: less_equal),
    culling: back,
    blend: opaque,
    outputs: [
        "depth",
    ],
    features: [
        "depth_only",
    ],
    profile_overrides: [],
)

