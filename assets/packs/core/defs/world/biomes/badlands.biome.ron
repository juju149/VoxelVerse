        terraces:  0.78,
        curve:     plateau(flatness: 0.35, threshold: 0.4),
        mountain:  1.0,
        slope_smooth: 0.05,
    ),

    palette: (
        grass:   (0.72, 0.44, 0.24),
        foliage: (0.56, 0.34, 0.16),
    ),

    vegetation: ["desert", "dry"],

    tags: ["desert", "dry", "badlands"],
)
