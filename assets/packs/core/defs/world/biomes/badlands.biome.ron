Biome(
    name: "Badlands",

    surface: (top: "red_sand", under: "coarse_dirt", depth: (2, 5)),
    slope: (above: 35, use: "andesite"),

    terrain: (
        height:    0.12,
        amplitude: 0.44,
        flatness:  0.26,
        noise:     "plateau_ridges",
        terraces:  0.78,
        curve:     plateau(flatness: 0.35, threshold: 0.4),
        mountain:  1.0,
        slope_smooth: 0.05,
    ),

    palette: (
        grass:   (0.74, 0.45, 0.23),
        foliage: (0.58, 0.35, 0.15),
        fog_bias: (0.04, 0.03, 0.01),
    ),

    vegetation: ["desert", "dry"],

    tags: ["desert", "dry", "badlands", "rocky", "mineral_rich", "plateau", "rare_ores"],
)
