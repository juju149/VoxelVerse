BlockModelDef(
    format_version: 1,
    display_name: "Full cube (six independent faces)",
    // Face layer slot names use local object axes (py = local +Y, ny = local -Y, ...).
    // Blocks referencing this model must provide a `materials` map with EXACTLY
    // these six keys.
    mesh: cube(
        face_layers: ["py", "ny", "pz", "nz", "px", "nx"],
        ambient_occlusion: true,
    ),
    collision: full_cube,
)
