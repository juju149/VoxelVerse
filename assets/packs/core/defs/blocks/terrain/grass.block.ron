// Grass Block — iconic surface soil, top face tinted by biome grass colour.
Block(
    name: "Grass Block",

    texture: Cube(
        top:    "blocks/grass_block/top",
        side:   "blocks/grass_block/side",
        bottom: "blocks/grass_block/bottom",
    ),
    render: opaque,
    tint: grass,

    hardness: 0.6,
    blast_resistance: 1.8,

    tool: shovel,
    drops: self,
    stack: 99,
    sound: grass,

    tags: [terrain, soil, supports_vegetation],
)
