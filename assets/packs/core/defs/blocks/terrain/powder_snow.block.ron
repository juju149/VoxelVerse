BlockDef(
    display_name: "Powder Snow",
    category: "terrain",
    physical: (
        solid: true,
        opaque: false,
        collision: soft_cube,
        hardness: 0.2,
        blast_resistance: 0.6,
        friction: 0.82,
        restitution: 0.0,
    ),
    visual: (
        shape: cube,
        render: alpha_test,
        materials: All("core:material/blocks/powder_snow/powder_snow_all"),
        ambient_occlusion: true,
        casts_shadow: true,
    ),
    gameplay: (
        preferred_tool: Some("core:tag/item/tool/shovel"),
        drops: "core:loot/blocks/powder_snow",
        placement: grid_aligned,
        replaceable: false,
    ),
    audio: (
        footstep: "core:sound/step/snow",
        break: "core:sound/break/snow",
        place: "core:sound/place/snow",
    ),
    tags: ["core:tag/block/terrain", "core:tag/block/snow", "core:tag/block/soft"],
    
)
