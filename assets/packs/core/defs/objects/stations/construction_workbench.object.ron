// Construction Workbench — unlocks all tier-1 tool and building recipes.
Object(
    name: "Construction Workbench",
    tags: ["#core:tag/station/construction", "#core:tag/block/furniture", "#core:tag/material/wood"],

    block: (
        texture: cube(
            top:    "blocks/crafting_bench/top",
            side:   "blocks/crafting_bench/front",
            bottom: "blocks/crafting_bench/bottom",
        ),
        render: opaque,
        hardness: 2.5,
        sound: wood,
    ),

    item: (
        stack: 1,
        category: station,
        visible_in_inventory: true,
        inventory_icon: block,
    ),

    station: (
        type: workbench,),

    mining: (
        tool: axe,
    ),

    recipes: [(
        kind: shapeless((
            ingredients: ["core:object/trees/oak_log", "core:object/trees/oak_log"],
        )),
        output: (item: "core:object/stations/construction_workbench", count: 1),
    )],
)
