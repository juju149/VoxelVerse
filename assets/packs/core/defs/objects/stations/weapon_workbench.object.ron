// Weapon Workbench — unlocks weapon and ammunition crafting.
Object(
    name: "Weapon Workbench",
    tags: ["#core:tag/station/weapon", "#core:tag/block/furniture"],

    block: (
        texture: cube(
            top:    "blocks/weapon_bench/top",
            side:   "blocks/weapon_bench/side",
            bottom: "blocks/weapon_bench/bottom",
        ),
        render: opaque,
        hardness: 2.5,
        sound: stone,
    ),

    item: (
        stack: 1,
        category: station,
        visible_in_inventory: true,
        inventory_icon: block,
    ),

    station: (
        type: workbench,),

    mining: (
        tool: pickaxe,
        drops: [(item: "core:object/stations/weapon_workbench")],
    ),

    recipes: [(
        station: "#core:tag/station/construction",
        kind: shapeless((
            ingredients: [
                "core:object/terrain/stone",
                "core:object/terrain/stone",
                "core:object/terrain/stone",
                "core:object/trees/oak_log",
                "core:object/trees/oak_log",
            ],
        )),
        output: (item: "core:object/stations/weapon_workbench", count: 1),
    )],
)
