        kind: shaped((
            pattern: [
                " SF",
                "S F",
                " SF",
            ],
            legend: { "S": "core:object/resources/plant_fiber", "F": "core:object/trees/oak_log" },
        )),
        output: (item: "core:object/weapons/wood_bow", count: 1),
