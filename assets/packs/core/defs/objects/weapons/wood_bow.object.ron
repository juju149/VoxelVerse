    name: "Wood Bow",
    tags: ["#core:tag/item/weapon", "#core:tag/weapon/bow", "#core:tag/weapon/ranged", "#core:tag/tier/0"],

    item: (
        stack: 1,
        category: weapon,
        visible_in_inventory: true,
        inventory_icon: texture("core:texture/items/weapons/wood_bow"),
        world_model: "core:voxel_model/equipment/weapons/bow_wood",
