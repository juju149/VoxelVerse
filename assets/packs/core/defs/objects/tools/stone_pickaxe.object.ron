    name: "Stone Pickaxe",
    tags: ["#core:tag/item/tool", "#core:tag/tool/pickaxe", "#core:tag/tier/1"],

    item: (
        stack: 1,
        category: tool,
        visible_in_inventory: true,
        inventory_icon: texture("core:texture/items/tools/stone_pickaxe"),
        world_model: "core:voxel_model/equipment/tools/pickaxe_stone",
    ),

    tool: (
        type: pickaxe,
        tier: 1,
        speed: 4.0,
        durability: 132,
    ),

    recipes: [(
        station: "#core:tag/station/construction",
        kind: shaped((
            pattern: [
                "SSS",
                " F ",
                " F ",
            ],
            legend: { "S": "core:object/terrain/stone", "F": "core:object/resources/plant_fiber" },
        )),
        output: (item: "core:object/tools/stone_pickaxe", count: 1),
    )],
)
