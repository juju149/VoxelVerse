// Torch - cheap placeable light for early exploration and building.
Object(
    name: "Torch",
    tags: ["#core:tag/item/decorative", "#core:tag/block/light_source", "#core:tag/tier/0"],

    block: (
        texture: all("blocks/torch/all"),
        render: cutout,
        solid: false,
        hardness: 0.1,
        sound: wood,
        shape: cross,
    ),

    item: (
        stack: 64,
        category: utility,
        visible_in_inventory: true,
        inventory_icon: texture("core:texture/items/utility/torch"),
    ),

    light: (
        level: 14,
        flicker: true,
        colour: (1.0, 0.72, 0.36),
    ),

    mining: (
        tool: any,
    ),

    recipes: [(
        kind: shapeless((
            ingredients: ["core:object/trees/oak_log", "core:object/resources/coal"],
        )),
        output: (item: "core:object/utility/torch", count: 4),
    )],
)
