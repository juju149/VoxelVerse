// Iron Ore — drops ore chunks; smelt in a furnace for ingots.
Object(
    name: "Iron Ore",
    tags: ["#core:tag/worldgen/ore", "#core:tag/material/stone"],

    block: (
        texture: all("blocks/iron_ore/all"),
        render: opaque,
        hardness: 3.0,
        sound: stone,
    ),

    item: (
        stack: 99,
        category: block,
        visible_in_inventory: true,
        inventory_icon: block,
    ),

    mining: (
        tool: pickaxe,
        tier: 1,
        drops: [(item: "core:object/resources/iron_ore_chunk", count: 1)],
    ),
)
