// Bedrock — unbreakable planet boundary.
Object(
    name: "Bedrock",
    tags: ["#core:tag/block/terrain", "#core:tag/block/unbreakable"],

    block: (
        texture: all("blocks/bedrock/all"),
        render: opaque,
        hardness: -1.0,      // negative = unbreakable
        sound: stone,
    ),

    item: (
        stack: 99,
        category: block,
        visible_in_inventory: true,
        inventory_icon: block,
    ),
)
