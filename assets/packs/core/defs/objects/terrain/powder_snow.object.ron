// Powder Snow — not solid, entities sink through it.
Object(
    name: "Powder Snow",
    tags: ["#core:tag/block/terrain", "#core:tag/material/snow"],

    block: (
        texture: all("blocks/powder_snow/all"),
        render: translucent,
        solid: false,
        hardness: 0.25,
        sound: snow,
    ),

    item: (
        stack: 99,
        category: block,
        visible_in_inventory: true,
        inventory_icon: block,
    ),

    mining: (
        tool: shovel,
        drops: [],           // melts, drops nothing
    ),
)
