// Grass Block — biome-tinted top, dirt bottom.
Object(
    name: "Grass Block",
    tags: ["#core:tag/block/terrain", "#core:tag/material/soil", "#core:tag/worldgen/supports_vegetation"],

    block: (
        texture: cube(
            top:    "blocks/grass_block/top",
            side:   "blocks/grass_block/side",
            bottom: "blocks/grass_block/bottom",
        ),
        render: opaque,
        tint: grass,         // top face receives biome grass colour
        hardness: 0.6,
        sound: grass,
    ),

    item: (
        stack: 99,
        category: block,
        visible_in_inventory: true,
        inventory_icon: block,
    ),

    mining: (
        tool: shovel,
        drops: [(item: "core:object/terrain/dirt", count: 1)],
    ),
)
