// Sound groups for blocks.
// Each word is a sound group id usable in Block(sound: group_name).
// The engine plays a random variant from the group on step/break/place.
Sounds(
    groups: {
        stone:  (pitch: 1.00, volume: 1.0),
        dirt:   (pitch: 1.05, volume: 0.9),
        grass:  (pitch: 1.10, volume: 0.9),
        wood:   (pitch: 1.00, volume: 0.8),
        sand:   (pitch: 1.05, volume: 0.8),
        snow:   (pitch: 1.00, volume: 0.7),
        leaves: (pitch: 1.10, volume: 0.7),
        none:   (pitch: 1.00, volume: 0.0),
    },
)
