BiomeDef(
    display_name: "Alpine Heights",
    surface: (
        top: "core:block/terrain/stone",
        under: "core:block/terrain/deepslate",
        depth_voxels: (1, 4),
        slope_override: Some((above_degrees: 30, top: "core:block/terrain/stone")),
    ),
    terrain: (
        base_height: 0.26,
        amplitude: 0.72,
        flatness: 0.06,
        hill_field: "core:field/rolling_hills",
        ridge_field: Some("core:field/mountain_sharp"),
        terrace_strength: 0.22,
    ),
    palette: (
        grass: (0.50, 0.62, 0.45),
        foliage: (0.32, 0.44, 0.34),
        fog_bias: (-0.02, -0.01, 0.04),
    ),
    placement: (
        vegetation_tags: ["core:tag/biome/cold", "core:tag/biome/mountain"],
        fauna_tags: ["core:tag/fauna/small_herbivore"],
        structure_tags: ["core:tag/structure/small"],
    ),
    tags: ["core:tag/biome/cold", "core:tag/biome/mountain"],
)
