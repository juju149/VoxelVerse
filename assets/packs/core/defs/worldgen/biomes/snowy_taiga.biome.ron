BiomeDef(
    display_name: "Snowy Taiga",
    surface: (
        top: "core:block/terrain/snow",
        under: "core:block/terrain/dirt",
        depth_voxels: (2, 6),
        slope_override: Some((above_degrees: 40, top: "core:block/terrain/stone")),
    ),
    terrain: (
        base_height: 0.04,
