BiomeDef(
    display_name: "Birch Forest",
    surface: (
        top: "core:block/terrain/grass",
        under: "core:block/terrain/dirt",
        depth_voxels: (2, 6),
        slope_override: Some((above_degrees: 42, top: "core:block/terrain/stone")),
    ),
    terrain: (
        base_height: 0.05,
