// Iron Ingot — smelting recipe.
//
// Input:  1× iron_ore_chunk (dropped when mining iron ore)
// Output: 1× iron_ingot
// Fuel:   800 ticks (≈ half a coal)
// Time:   10 seconds
RecipeDef(
    format_version: 1,
    result: (item: "core:item/resource/iron_ingot", count: 1),
    station: Some("core:tag/station/furnace"),
    group: Some("smelting"),
    recipe: Smelting((
        ingredient: Item("core:item/resource/iron_ore_chunk"),
        fuel: 800,
        smelt_seconds: 10.0,
    )),
)
